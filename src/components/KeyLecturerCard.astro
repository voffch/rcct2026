---
const { img, name, title } = Astro.props;
const imgPath = `/img/key_lecturers/${img}`;
---

<details>
  <summary>
    <button class="responsive border" onclick="this.closest('details').open = !this.closest('details').open">
      { title && <div class="presentation-title"><strong set:html={title}></strong></div> }
      <div>{ name }</div>
    </button>
  </summary>
  <article class="key-lecturer">
    <h5>{ name }</h5>
    { img && <img src={ imgPath } loading="lazy" alt="photo" /> }
    <div>
      <slot/>
    </div>
  </article>
</details>

<style>
  summary button {
    display: flex;
    flex-direction: column;
    align-items: center;
    height: fit-content;
    padding: 0.5rem;
    border-radius: 0.25rem;
  }
  .key-lecturer {
    overflow-y: auto;
  }
  .key-lecturer :global(ul),
  .key-lecturer :global(ol) {
    padding-left: 0;
    list-style-position: inside;
  }
  .key-lecturer img {
    float: left;
    max-width: 16rem;
    max-height: 24rem;
    margin: 1rem 1rem 1rem 0;
    border-radius: 1rem;
  }
  .key-lecturer h5 {
    margin-top: 0;
  }
  @media all and (max-width: 600px) {
    .key-lecturer {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .key-lecturer img {
      max-width: 12rem;
      margin: 0;
      align-self: center;
    }
  }
</style>