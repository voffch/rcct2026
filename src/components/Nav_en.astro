<script is:inline>
  const smallScreenMenuLinks = document.querySelectorAll('#small-screen-menu a');
  smallScreenMenuLinks.forEach((a) => a.addEventListener('click', () => {
    document.querySelector('#small-screen-menu').close();
  }));
</script>